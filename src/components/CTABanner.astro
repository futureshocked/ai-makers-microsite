---
interface Props {
  title?: string;
  sub?: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
}

const {
  title = 'Ready to build with AI?',
  sub = 'Join the course and go from idea to deployed software.',
  primaryLabel = 'Enroll Now',
  primaryHref = 'https://connect.techexplorations.com',
  secondaryLabel = 'Join the Email List',
  secondaryHref = 'https://connect.techexplorations.com',
} = Astro.props;
---

<section class="cta-banner bg-circuit">
  <div class="container cta-inner">
    <div class="cta-content">
      <p class="section-label">Get Started</p>
      <h2>{title}</h2>
      <p class="cta-sub">{sub}</p>
    </div>
    <div class="cta-actions">
      <a href={primaryHref} target="_blank" rel="noopener" class="btn btn-primary btn-lg">{primaryLabel}</a>
      <a href={secondaryHref} target="_blank" rel="noopener" class="btn btn-secondary btn-lg">{secondaryLabel}</a>
    </div>
  </div>
</section>

<style>
  .cta-banner {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 72px 0;
    position: relative;
    overflow: hidden;
  }
  .cta-banner::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 50%, rgba(0,200,255,0.06) 0%, transparent 70%);
    pointer-events: none;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 40px;
    position: relative;
  }
  .cta-content { flex: 1; max-width: 520px; }
  .cta-content h2 { margin-bottom: 12px; }
  .cta-sub { font-size: 1.1rem; }
  .cta-actions {
    display: flex;
    gap: 16px;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .cta-inner { flex-direction: column; align-items: flex-start; }
    .cta-actions { width: 100%; }
    .cta-actions a { flex: 1; justify-content: center; }
  }
</style>
