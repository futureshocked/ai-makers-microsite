---
/**
 * MediaFigure — lecture screenshot or slide image with a stylized legend.
 *
 * Props:
 *   src            — path to the screenshot image (relative to public/). Omit for placeholder.
 *   alt            — alt text for the image
 *   caption        — main legend text (what the screenshot shows)
 *   subcaption     — monospace source label (e.g. "Module 1, L1.2 · Slide 3")
 *   placeholderLabel — short label shown inside the placeholder (e.g. "L1.2 slide")
 *   aspect         — CSS aspect-ratio override, default "16 / 9"
 *   desc           — optional paragraph describing what the image shows
 */
interface Props {
  src?: string;
  alt?: string;
  caption: string;
  subcaption: string;
  placeholderLabel?: string;
  aspect?: string;
  desc?: string;
}
const {
  src,
  alt = '',
  caption,
  subcaption,
  placeholderLabel = 'Lecture screenshot',
  aspect = '16 / 9',
  desc,
} = Astro.props;
---

<figure class="media-figure screenshot-figure">
  <div class="screenshot-wrapper" style={`aspect-ratio: ${aspect}`}>
    {src ? (
      <img src={src} alt={alt} loading="lazy" decoding="async" />
    ) : (
      <div class="ss-placeholder" role="img" aria-label={alt || caption}>
        <div class="ssp-bg"></div>
        <div class="ssp-content">
          <div class="ssp-icon" aria-hidden="true">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none">
              <rect x="2" y="4" width="24" height="17" rx="2" stroke="#00c8ff" stroke-width="1.2" fill="none"/>
              <path d="M10 21v3M18 21v3M7 24h14" stroke="#00c8ff" stroke-width="1.2" stroke-linecap="round"/>
              <rect x="6" y="8" width="16" height="9" rx="1" fill="rgba(0,200,255,0.06)" stroke="rgba(0,200,255,0.2)" stroke-width="0.8"/>
              <path d="M9 12h10M9 14.5h6" stroke="rgba(0,200,255,0.4)" stroke-width="0.8" stroke-linecap="round"/>
            </svg>
          </div>
          <p class="ssp-label">{placeholderLabel}</p>
          <p class="ssp-sub mono">Screenshot placeholder</p>
        </div>
      </div>
    )}
  </div>

  <figcaption class="media-caption">
    <span class="mc-icon slide-icon" aria-hidden="true">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
        <rect x="1" y="1.5" width="12" height="8.5" rx="1.2" stroke="currentColor" stroke-width="1.1"/>
        <path d="M5 10v2.5M9 10v2.5M3.5 12.5h7" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
        <path d="M3.5 5h7M3.5 7h4.5" stroke="currentColor" stroke-width="0.9" stroke-linecap="round" opacity="0.6"/>
      </svg>
    </span>
    <div class="mc-text">
      <span class="mc-caption">{caption}</span>
      <span class="mc-sub mono">{subcaption}</span>
      {desc && <p class="mc-desc">{desc}</p>}
    </div>
  </figcaption>
</figure>

<style>
  .media-figure {
    display: flex;
    flex-direction: column;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--border);
    background: var(--surface);
  }

  .screenshot-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--bg);
  }
  .screenshot-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Placeholder */
  .ss-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ssp-bg {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle, rgba(0, 200, 255, 0.05) 1px, transparent 1px),
      linear-gradient(rgba(0, 200, 255, 0.015) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 200, 255, 0.015) 1px, transparent 1px);
    background-size: 20px 20px, 40px 40px, 40px 40px;
    background-color: var(--bg);
  }
  .ssp-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 30% 60%, rgba(124,58,237,0.04) 0%, transparent 60%);
  }
  .ssp-content {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
    padding: 20px;
  }
  .ssp-icon {
    width: 52px; height: 52px;
    border-radius: var(--radius-md);
    background: rgba(0,200,255,0.08);
    border: 1px solid rgba(0,200,255,0.2);
    display: flex; align-items: center; justify-content: center;
  }
  .ssp-label { font-size: 0.8rem; font-weight: 600; color: var(--text-muted); }
  .ssp-sub { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-dim); }

  /* Caption legend — shared style via global (duplicated here for scoping) */
  .media-caption {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 11px 14px;
    background: var(--surface-2);
    border-top: 2px solid var(--accent);
  }
  .slide-icon { color: var(--accent); flex-shrink: 0; margin-top: 1px; }
  .mc-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .mc-caption {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.3;
  }
  .mc-sub {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }
  .mc-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.55;
    margin-top: 6px;
  }
</style>
