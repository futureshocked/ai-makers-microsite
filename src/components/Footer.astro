---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="divider-accent"></div>
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo" aria-label="AI Coding for Makers">
        <svg width="24" height="24" viewBox="0 0 28 28" fill="none" aria-hidden="true">
          <rect x="2" y="2" width="24" height="24" rx="4" stroke="#00c8ff" stroke-width="1.5" fill="none"/>
          <path d="M8 14h4m4 0h4M14 8v4m0 4v4" stroke="#00c8ff" stroke-width="1.5" stroke-linecap="round"/>
          <circle cx="14" cy="14" r="2" fill="#00c8ff"/>
          <circle cx="8" cy="8" r="1.5" fill="#00c8ff" opacity="0.4"/>
          <circle cx="20" cy="8" r="1.5" fill="#00c8ff" opacity="0.4"/>
          <circle cx="8" cy="20" r="1.5" fill="#00c8ff" opacity="0.4"/>
          <circle cx="20" cy="20" r="1.5" fill="#00c8ff" opacity="0.4"/>
        </svg>
        <span>AI Coding for Makers</span>
      </a>
      <p class="footer-tagline">A course by <a href="https://techexplorations.com" target="_blank" rel="noopener">Tech Explorations</a></p>
    </div>

    <nav class="footer-nav" aria-label="Footer navigation">
      <div class="footer-nav-col">
        <span class="footer-nav-label">Course</span>
        <a href="/">Home</a>
        <a href="/curriculum">Curriculum</a>
        <a href="/projects">Projects</a>
      </div>
      <div class="footer-nav-col">
        <span class="footer-nav-label">Learn</span>
        <a href="/five-levels">Five Levels</a>
        <a href="/workflow">Workflow</a>
      </div>
      <div class="footer-nav-col">
        <span class="footer-nav-label">More</span>
        <a href="/resources">Resources</a>
        <a href="https://connect.techexplorations.com/so/ai-coding" target="_blank" rel="noopener">Tech Explorations</a>
        <a href="https://connect.techexplorations.com/?ff_landing=11" target="_blank" rel="noopener">Email Updates</a>
      </div>
    </nav>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <span>&copy; {year} Tech Explorations. All rights reserved.</span>
      <span class="mono footer-mono">// ai.techexplorations.com</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--surface);
    border-top: 1px solid var(--border);
    margin-top: 80px;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    gap: 48px;
    padding: 56px 24px 48px;
  }
  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 240px;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
    font-weight: 600;
    font-size: 0.95rem;
  }
  .footer-logo:hover { text-decoration: none; }
  .footer-tagline { font-size: 0.85rem; color: var(--text-dim); }
  .footer-tagline a { color: var(--text-muted); }
  .footer-tagline a:hover { color: var(--accent); }

  .footer-nav { display: flex; gap: 48px; }
  .footer-nav-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-nav-label {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-family: var(--font-mono);
    margin-bottom: 4px;
  }
  .footer-nav-col a {
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.15s;
  }
  .footer-nav-col a:hover { color: var(--accent); text-decoration: none; }

  .footer-bottom {
    border-top: 1px solid var(--border);
    padding: 16px 24px;
  }
  .footer-bottom-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-dim);
  }
  .footer-mono { font-family: var(--font-mono); color: var(--accent); opacity: 0.5; font-size: 0.75rem; }

  @media (max-width: 768px) {
    .footer-inner { flex-direction: column; padding: 40px 24px 32px; }
    .footer-nav { gap: 32px; flex-wrap: wrap; }
    .footer-bottom-inner { flex-direction: column; gap: 6px; text-align: center; }
  }
</style>
